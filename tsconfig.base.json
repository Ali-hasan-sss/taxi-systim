{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@taxi/types/*": ["packages/types/src/*"],
      "@taxi/utils/*": ["packages/utils/src/*"],
      "@taxi/config/*": ["packages/config/src/*"],
      "@taxi/ui/*": ["packages/ui/src/*"]
    }
  }
}
