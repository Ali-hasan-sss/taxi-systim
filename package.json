{
  "name": "taxi-office-monorepo",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @taxi/api dev",
    "dev:admin": "pnpm --filter @taxi/admin-dashboard dev",
    "admin:pm2:start": "pm2 start apps/admin-dashboard/ecosystem.config.cjs",
    "dev:driver": "pnpm --filter @taxi/driver-app dev",
    "dev:coordinator": "pnpm --filter @taxi/coordinator-app dev",
    "eas:coordinator:android:preview": "pnpm --filter @taxi/coordinator-app run eas:android:preview",
    "eas:coordinator:android:production": "pnpm --filter @taxi/coordinator-app run eas:android:production",
    "eas:driver:android:preview": "pnpm --filter @taxi/driver-app run eas:android:preview",
    "eas:driver:android:production": "pnpm --filter @taxi/driver-app run eas:android:production",
    "db:migrate:api": "pnpm --filter @taxi/api run prisma:migrate:deploy",
    "db:migrate:api:dev": "pnpm --filter @taxi/api run prisma:migrate",
    "db:reset:api": "pnpm --filter @taxi/api run prisma:reset",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@react-native/debugger-frontend": "0.81.5",
    "eas-cli": "18.11.0",
    "prettier": "^3.3.3",
    "turbo": "^2.0.14",
    "typescript": "^5.6.2"
  }
}
