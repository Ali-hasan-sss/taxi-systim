{
  "expo": {
    "name": "منسق التكسي",
    "slug": "taxi-coordinator",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "taxi-coordinator",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/logo-icon.png",
    "splash": {
      "image": "./assets/images/logo-removebg-preview.png",
      "resizeMode": "contain",
      "backgroundColor": "#1c1917"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نحتاج موقعك كنقطة مرجعية لإرسال الطلب لأقرب 3 سائقين متصلين."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1c1917",
          "image": "./assets/images/logo-removebg-preview.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#1c1917"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-icon.png",
          "color": "#ea580c",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "نحتاج الكاميرا لإرسال صور في المحادثات.",
          "photosPermission": false
        }
      ],
      "expo-audio",
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#1c1917",
          "style": "light",
          "borderColor": "#1c1917",
          "position": "relative"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.taxioffice.coordinator",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["whatsapp", "whatsapp-business"]
      },
      "splash": {
        "backgroundColor": "#1c1917"
      }
    },
    "android": {
      "package": "com.taxioffice.coordinator",
      "googleServicesFile": "./google-services.json",
      "versionCode": 3,
      "usesCleartextTraffic": true,
      "supportsRTL": true,
      "softwareKeyboardLayoutMode": "resize",
      "navigationBar": {
        "backgroundColor": "#1c1917",
        "barStyle": "light-content"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-icon.png",
        "backgroundColor": "#1c1917"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "router": {},
      "mapTileUrlTemplate": "https://a.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png",
      "eas": {
        "projectId": "940978d6-15fc-421b-974b-f68c94e550a1"
      }
    },
    "owner": "alihasan_123"
  }
}
