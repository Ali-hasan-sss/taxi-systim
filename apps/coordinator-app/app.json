{
  "expo": {
    "name": "منسق التكسي",
    "slug": "taxi-coordinator",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "taxi-coordinator",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/logo-icon.png",
    "splash": {
      "image": "./assets/images/logo-removebg-preview.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نحتاج موقعك كنقطة مرجعية لإرسال الطلب لأقرب 3 سائقين متصلين."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f172a",
          "image": "./assets/images/logo-removebg-preview.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#0f172a"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-icon.png",
          "color": "#38bdf8",
          "defaultChannel": "default"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.taxioffice.coordinator",
      "splash": {
        "backgroundColor": "#0f172a"
      }
    },
    "android": {
      "package": "com.taxioffice.coordinator",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "supportsRTL": true,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-icon.png",
        "backgroundColor": "#0f172a"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "router": {},
      "mapTileUrlTemplate": "https://a.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png",
      "eas": {
        "projectId": "940978d6-15fc-421b-974b-f68c94e550a1"
      }
    },
    "owner": "alihasan_123"
  }
}
