generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COORDINATOR
  DRIVER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  ARRIVED
  EN_ROUTE_TO_CUSTOMER
  STARTED
  STUCK
  COMPLETED
  CANCELLED
}

enum OrderBroadcastTarget {
  ALL
  NEAREST_THREE
}

/** نوع سيارة السائق (يحدده الأدمن) */
enum VehicleKind {
  PUBLIC
  PRIVATE
}

/** متطلب نوع السيارة للطلب (يحدده المنسق عند الإنشاء) */
enum OrderVehicleRequirement {
  ANY
  PUBLIC
  PRIVATE
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum CommissionPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum FinancialTransactionType {
  COMMISSION_CREATED
  COMMISSION_PAYMENT
  MANUAL_ADJUSTMENT
}

model User {
  id             String         @id @default(cuid())
  email          String?        @unique
  passwordHash   String
  fullName       String
  phone          String?        @unique
  role           Role
  isActive       Boolean        @default(true)
  /** رمز Expo Push لجهاز واحد (آخر تسجيل من تطبيق السائق/المنسق) */
  expoPushToken  String?
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  coordinator    Coordinator?
  driver         Driver?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Driver {
  id               String                  @id @default(cuid())
  userId           String                  @unique
  /** رقم اللوحة */
  vehicleNumber    String?
  vehicleBrand     String?
  vehicleKind      VehicleKind?
  vehicleColor     String?
  isOnline         Boolean                 @default(false)
  isBusy           Boolean                 @default(false)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders           Order[]
  locationHistory  DriverLocationHistory[]
  commissions      Commission[]
  balances         DriverBalance[]
  payments         CommissionPayment[]
  transactions     FinancialTransaction[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model Coordinator {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]  @relation("CreatedByCoordinator")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Order {
  id               String       @id @default(cuid())
  customerName     String
  customerPhone    String?
  pickupAddress    String
  dropoffAddress   String
  pickupLat        Float?
  pickupLng        Float?
  dropoffLat       Float?
  dropoffLng       Float?
  notes            String?
  vehicleRequirement OrderVehicleRequirement @default(ANY)
  amount           Decimal      @db.Decimal(10, 2)
  broadcastTarget  OrderBroadcastTarget @default(ALL)
  status           OrderStatus  @default(PENDING)
  driverId         String?
  coordinatorId    String
  acceptedAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  driver           Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  coordinator      Coordinator  @relation("CreatedByCoordinator", fields: [coordinatorId], references: [id], onDelete: Restrict)
  commission       Commission?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  body       String
  readAt     DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model DriverLocationHistory {
  id         String   @id @default(cuid())
  driverId   String
  lat        Float
  lng        Float
  recordedAt DateTime @default(now())
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id              String         @id @default(cuid())
  key             String         @unique
  commissionType  CommissionType
  commissionValue Decimal        @db.Decimal(10, 2)
  updatedByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Commission {
  id                  String                  @id @default(cuid())
  orderId             String                  @unique
  driverId            String
  commissionType      CommissionType
  commissionValue     Decimal                 @db.Decimal(10, 2)
  orderAmount         Decimal                 @db.Decimal(10, 2)
  calculatedCommission Decimal                @db.Decimal(10, 2)
  paymentStatus       CommissionPaymentStatus @default(UNPAID)
  paidAmount          Decimal                 @db.Decimal(10, 2) @default(0)
  remainingAmount     Decimal                 @db.Decimal(10, 2)
  notes               String?
  paidAt              DateTime?
  order               Order                   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  driver              Driver                  @relation(fields: [driverId], references: [id], onDelete: Restrict)
  payments            CommissionPayment[]
  createdAt           DateTime                @default(now())
}

model CommissionPayment {
  id            String   @id @default(cuid())
  commissionId  String
  driverId      String
  amount        Decimal  @db.Decimal(10, 2)
  notes         String?
  paidByUserId  String?
  paidAt        DateTime @default(now())
  commission    Commission @relation(fields: [commissionId], references: [id], onDelete: Restrict)
  driver        Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
}

model DriverBalance {
  id                   String   @id @default(cuid())
  driverId             String   @unique
  totalEarnings        Decimal  @db.Decimal(10, 2) @default(0)
  totalCommissions     Decimal  @db.Decimal(10, 2) @default(0)
  totalPaidCommissions Decimal  @db.Decimal(10, 2) @default(0)
  remainingDebt        Decimal  @db.Decimal(10, 2) @default(0)
  availableBalance     Decimal  @db.Decimal(10, 2) @default(0)
  updatedAt            DateTime @updatedAt
  driver               Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model FinancialTransaction {
  id             String                   @id @default(cuid())
  driverId       String
  type           FinancialTransactionType
  amount         Decimal                  @db.Decimal(10, 2)
  referenceId    String?
  notes          String?
  createdByUserId String?
  createdAt      DateTime                 @default(now())
  driver         Driver                   @relation(fields: [driverId], references: [id], onDelete: Restrict)
}
