generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COORDINATOR
  DRIVER
}

enum OrderStatus {
  PENDING
  ACCEPTED
  ARRIVED
  EN_ROUTE_TO_CUSTOMER
  STARTED
  STUCK
  COMPLETED
  CANCELLED
}

enum OrderBroadcastTarget {
  ALL
  NEAREST_THREE
}

/** نوع سيارة السائق (يحدده الأدمن) */
enum VehicleKind {
  PUBLIC
  PRIVATE
  VIP
}

/** متطلب نوع السيارة للطلب (يحدده المنسق عند الإنشاء) */
enum OrderVehicleRequirement {
  ANY
  PUBLIC
  PRIVATE
  VIP
}

enum OrderSource {
  APP
  WEB_PUBLIC
}

/** نوع آلية العرض */
enum PromotionChannel {
  /** عبر رابط الويب (?promo=CODE) */
  WEB_LINK
  /** عند بلوغ عدد طلبات الزبون للعتبة */
  LOYALTY
}

enum PromotionRewardType {
  /** خصم مبلغ ثابت من الأجرة */
  FIXED_DISCOUNT
  /** طلب مجاني (خصم كامل الأجرة) */
  FREE_ORDER
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum CommissionPaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum FinancialTransactionType {
  COMMISSION_CREATED
  COMMISSION_PAYMENT
  MANUAL_ADJUSTMENT
}

enum ChatRoomType {
  GLOBAL
  ORDER
}

model User {
  id             String         @id @default(cuid())
  email          String?        @unique
  passwordHash   String
  fullName       String
  phone          String?        @unique
  role           Role
  isActive       Boolean        @default(true)
  /** رمز Expo Push لجهاز واحد (آخر تسجيل من تطبيق السائق/المنسق) */
  expoPushToken  String?
  refreshTokens  RefreshToken[]
  notifications  Notification[]
  coordinator    Coordinator?
  driver         Driver?
  chatMessages   ChatMessage[]
  chatReceipts   ChatMessageReceipt[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model Driver {
  id               String                  @id @default(cuid())
  userId           String                  @unique
  /** رقم اللوحة */
  vehicleNumber    String?
  vehicleBrand     String?
  vehicleKind      VehicleKind?
  vehicleColor     String?
  isOnline         Boolean                 @default(false)
  isBusy           Boolean                 @default(false)
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders           Order[]
  locationHistory  DriverLocationHistory[]
  commissions      Commission[]
  balances         DriverBalance[]
  payments         CommissionPayment[]
  transactions     FinancialTransaction[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
}

model Coordinator {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     Order[]  @relation("CreatedByCoordinator")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

/** زبون يُنشأ تلقائيًا من رقم الهاتف عند إنشاء الطلب */
model Customer {
  id          String    @id @default(cuid())
  /** رقم موحّد للمطابقة (مثل 9639…) */
  phone       String    @unique
  name        String?
  ordersCount Int       @default(0)
  lastOrderAt DateTime?
  orders      Order[]
  promoRedemptions PromotionRedemption[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([ordersCount])
  @@index([lastOrderAt])
}

/** عروض خصم يضيفها المدير للزبائن */
model Promotion {
  id              String               @id @default(cuid())
  title           String
  description     String?
  channel         PromotionChannel
  rewardType      PromotionRewardType
  /** عتبة عدد الطلبات (مثلاً كل 5 طلبات) */
  ordersThreshold Int
  /** مبلغ الخصم عند FIXED_DISCOUNT */
  discountAmount  Decimal?             @db.Decimal(10, 2)
  /** رمز العرض لرابط الويب — مطلوب لـ WEB_LINK */
  code            String?              @unique
  isActive        Boolean              @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  createdByUserId String?
  redemptions     PromotionRedemption[]
  orders          Order[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([isActive, channel])
}

model PromotionRedemption {
  id             String     @id @default(cuid())
  promotionId    String
  customerId     String
  orderId        String     @unique
  discountAmount Decimal    @db.Decimal(10, 2)
  milestoneCount Int
  promotion      Promotion  @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  customer       Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@index([promotionId, customerId])
}

model Order {
  id               String       @id @default(cuid())
  customerName     String
  customerPhone    String?
  customerId       String?
  pickupAddress    String
  dropoffAddress   String
  pickupLat        Float?
  pickupLng        Float?
  dropoffLat       Float?
  dropoffLng       Float?
  notes            String?
  vehicleRequirement OrderVehicleRequirement @default(ANY)
  source           OrderSource    @default(APP)
  /** null للطلبات الواردة من الويب قبل بثها لغرفة السائقين */
  driversNotifiedAt DateTime?
  amount           Decimal      @db.Decimal(10, 2)
  /** الأجرة قبل الخصم الترويجي */
  originalAmount   Decimal?     @db.Decimal(10, 2)
  /** قيمة الخصم المطبّق على الزبون */
  discountAmount   Decimal      @default(0) @db.Decimal(10, 2)
  promotionId      String?
  /** متى سُجّل تعويض السائق عن الخصم */
  promoCompensatedAt DateTime?
  broadcastTarget  OrderBroadcastTarget @default(ALL)
  status           OrderStatus  @default(PENDING)
  driverId         String?
  coordinatorId    String
  acceptedAt       DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  /** تاريخ إرسال معلومات السائق للزبون عبر واتساب (منع الإرسال المكرر) */
  customerInfoSentAt DateTime?
  /** تاريخ إرسال الفاتورة للزبون عبر واتساب (منع الإرسال المكرر) */
  invoiceSentAt      DateTime?
  customer         Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  promotion        Promotion?   @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  promoRedemption  PromotionRedemption?
  driver           Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)
  coordinator      Coordinator  @relation("CreatedByCoordinator", fields: [coordinatorId], references: [id], onDelete: Restrict)
  commission       Commission?
  chatRoom         ChatRoom?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([customerId])
  @@index([promotionId])
}

model ChatRoom {
  id               String        @id @default(cuid())
  type             ChatRoomType
  orderId          String?       @unique
  title            String?
  archivedAt       DateTime?
  archivedByUserId String?
  order            Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  messages         ChatMessage[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([type])
  @@index([type, archivedAt])
}

model ChatMessage {
  id             String    @id @default(cuid())
  roomId         String
  senderUserId   String
  body           String?
  imagePath      String?
  imageExpiresAt DateTime?
  voicePath      String?
  voiceExpiresAt DateTime?
  voiceDurationMs Int?
  room           ChatRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender         User      @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  receipts       ChatMessageReceipt[]
  createdAt      DateTime  @default(now())

  @@index([roomId, createdAt])
}

model ChatMessageReceipt {
  messageId   String
  userId      String
  deliveredAt DateTime?
  readAt      DateTime?
  message     ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId])
}

model Notification {
  id         String   @id @default(cuid())
  userId     String
  title      String
  body       String
  readAt     DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model DriverLocationHistory {
  id         String   @id @default(cuid())
  driverId   String
  lat        Float
  lng        Float
  recordedAt DateTime @default(now())
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model SystemSettings {
  id              String         @id @default(cuid())
  key             String         @unique
  commissionType  CommissionType
  commissionValue Decimal        @db.Decimal(10, 2)
  updatedByUserId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Commission {
  id                  String                  @id @default(cuid())
  orderId             String                  @unique
  driverId            String
  commissionType      CommissionType
  commissionValue     Decimal                 @db.Decimal(10, 2)
  orderAmount         Decimal                 @db.Decimal(10, 2)
  calculatedCommission Decimal                @db.Decimal(10, 2)
  paymentStatus       CommissionPaymentStatus @default(UNPAID)
  paidAmount          Decimal                 @db.Decimal(10, 2) @default(0)
  remainingAmount     Decimal                 @db.Decimal(10, 2)
  notes               String?
  paidAt              DateTime?
  order               Order                   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  driver              Driver                  @relation(fields: [driverId], references: [id], onDelete: Restrict)
  payments            CommissionPayment[]
  createdAt           DateTime                @default(now())
}

model CommissionPayment {
  id            String   @id @default(cuid())
  commissionId  String
  driverId      String
  amount        Decimal  @db.Decimal(10, 2)
  notes         String?
  paidByUserId  String?
  paidAt        DateTime @default(now())
  commission    Commission @relation(fields: [commissionId], references: [id], onDelete: Restrict)
  driver        Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
}

model DriverBalance {
  id                   String   @id @default(cuid())
  driverId             String   @unique
  totalEarnings        Decimal  @db.Decimal(10, 2) @default(0)
  totalCommissions     Decimal  @db.Decimal(10, 2) @default(0)
  totalPaidCommissions Decimal  @db.Decimal(10, 2) @default(0)
  remainingDebt        Decimal  @db.Decimal(10, 2) @default(0)
  availableBalance     Decimal  @db.Decimal(10, 2) @default(0)
  updatedAt            DateTime @updatedAt
  driver               Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
}

model FinancialTransaction {
  id             String                   @id @default(cuid())
  driverId       String
  type           FinancialTransactionType
  amount         Decimal                  @db.Decimal(10, 2)
  referenceId    String?
  notes          String?
  createdByUserId String?
  createdAt      DateTime                 @default(now())
  driver         Driver                   @relation(fields: [driverId], references: [id], onDelete: Restrict)
}
