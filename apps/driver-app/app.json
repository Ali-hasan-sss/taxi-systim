{
  "expo": {
    "name": "كابتن برو",
    "slug": "taxi-driver",
    "version": "1.0.10",
    "orientation": "portrait",
    "scheme": "taxi-driver",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/logo-icon.png",
    "splash": {
      "image": "./assets/images/logo-removebg-preview.png",
      "resizeMode": "contain",
      "backgroundColor": "#fffbeb"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "30.0.14904198"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نستخدم موقعك لعرض الطلبات المناسبة لقربك من نقطة الانطلاق."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fffbeb",
          "image": "./assets/images/logo-removebg-preview.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#fffbeb"
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-icon.png",
          "color": "#ea580c",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "نحتاج الكاميرا لإرسال صور في المحادثات.",
          "photosPermission": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "نحتاج الميكروفون لإرسال رسائل صوتية في المحادثات."
        }
      ],
      [
        "expo-navigation-bar",
        {
          "backgroundColor": "#fffbeb",
          "style": "dark",
          "borderColor": "#fffbeb",
          "position": "relative"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.taxioffice.driver",
      "supportsTablet": true,
      "splash": {
        "backgroundColor": "#fffbeb"
      }
    },
    "android": {
      "package": "com.taxioffice.driver",
      "googleServicesFile": "./google-services.json",
      "versionCode": 10,
      "usesCleartextTraffic": true,
      "supportsRTL": true,
      "softwareKeyboardLayoutMode": "resize",
      "navigationBar": {
        "backgroundColor": "#fffbeb",
        "barStyle": "dark-content"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-icon.png",
        "backgroundColor": "#fffbeb"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5adbf73-b1d3-4b5e-8893-e95577612349"
      }
    },
    "owner": "alihasan_123"
  }
}
