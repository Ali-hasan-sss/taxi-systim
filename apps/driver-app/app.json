{
  "expo": {
    "name": "سائق التكسي",
    "slug": "taxi-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "taxi-driver",
    "userInterfaceStyle": "light",
    "icon": "./assets/images/logo-icon.png",
    "splash": {
      "image": "./assets/images/logo-removebg-preview.png",
      "resizeMode": "contain",
      "backgroundColor": "#f8fafc"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "نستخدم موقعك لعرض الطلبات المناسبة لقربك من نقطة الانطلاق."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f8fafc",
          "image": "./assets/images/logo-removebg-preview.png",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#f8fafc"
          }
        }
      ],
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo-icon.png",
          "color": "#2563eb",
          "defaultChannel": "default"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "com.taxioffice.driver",
      "supportsTablet": true,
      "splash": {
        "backgroundColor": "#f8fafc"
      }
    },
    "android": {
      "package": "com.taxioffice.driver",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo-icon.png",
        "backgroundColor": "#f8fafc"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "router": {},
      "eas": {}
    },
    "owner": "alihasan_123"
  }
}
