{
  "cli": {
    "version": ">=18.11.0",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": true
  },
  "build": {
    "monorepo": {
      "pnpm": "10.0.0",
      "cache": {
        "key": "driver-pnpm"
      },
      "env": {
        "EXPO_USE_FAST_RESOLVER": "1"
      }
    },
    "preview": {
      "extends": "monorepo",
      "prebuildCommand": "node ../../scripts/verify-google-services.cjs apps/driver-app",
      "distribution": "internal",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "1",
        "SKIP_PRISMA_POSTINSTALL": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "monorepo",
      "prebuildCommand": "node ../../scripts/verify-google-services.cjs apps/driver-app",
      "distribution": "store",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "1",
        "SKIP_PRISMA_POSTINSTALL": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
